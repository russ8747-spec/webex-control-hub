# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Your Webex admin personal access token (from developer.webex.com)
# Required scopes:
#   spark-admin:calling_cdr_read      (for call records)
#   spark-admin:locations_read        (for reading locations)
#   spark-admin:locations_write       (for creating/updating locations)
#   spark-admin:telephony_config_read (for reading auto attendants)
#   spark-admin:telephony_config_write(for creating/updating auto attendants)
WEBEX_ACCESS_TOKEN=your_token_here

# Your Webex organization ID (found in Control Hub > Account)
WEBEX_ORG_ID=your_org_id_here
